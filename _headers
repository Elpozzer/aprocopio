# Custom headers for Cloudflare Pages — A Procópio
# X-Frame-Options e X-Content-Type-Options DEVEM ser enviados apenas via HTTP header, não via <meta>
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://use.fontawesome.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://use.fontawesome.com; font-src 'self' https://fonts.gstatic.com https://use.fontawesome.com; img-src 'self' data: https://images.unsplash.com https://dcdn-us.mitiendanube.com https://maps.googleapis.com https://maps.gstatic.com https://*.fbcdn.net https://*.instagram.com; frame-src https://maps.google.com https://www.google.com; connect-src 'self' https://static.cloudflareinsights.com; frame-ancestors 'none';

# Cache static assets aggressively for ultra-fast loading times
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=86400, must-revalidate
